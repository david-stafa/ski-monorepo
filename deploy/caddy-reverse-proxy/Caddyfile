# Railway / Docker reverse proxy: one public URL → split traffic.
#
# Railway terminates TLS at the edge and forwards HTTP to this service on PORT.
# Do not use https:// as the site address here — that enables ACME/Let's Encrypt
# inside the container and HTTP-01 validation will fail.
#
# Required env:
#   PORT        — Railway sets this (e.g. 8080).
#   API_URL     — full upstream URL with scheme AND port (http://host alone → port 80 → refused).
#   CLIENT_URL  — same, e.g. http://frontend.railway.internal:3000
#
# Railway: `http://host` without a port uses 80 — your apps listen on each service’s PORT.
# Use an explicit port, e.g. :3000, or reference variables (see Railway private networking docs).
# Note: ${{service.PORT}} only works if that service has a *manually defined* PORT variable
# for references; the runtime-injected PORT is not available to other services that way.
#   API_URL=http://${{backend.RAILWAY_PRIVATE_DOMAIN}}:3001
#   CLIENT_URL=http://${{frontend.RAILWAY_PRIVATE_DOMAIN}}:3000
#
# Rebuild the web app so the browser uses relative `/api` or your public Railway URL.
{
	admin off
	servers {
		trusted_proxies static private_ranges
	}
}

:{$PORT} {
	reverse_proxy /api/* {$API_URL} {
		lb_try_duration 30s
		lb_try_interval 1s
	}
	reverse_proxy {$CLIENT_URL} {
		lb_try_duration 30s
		lb_try_interval 1s
	}
}
